TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=your_api_hash_here

# Optional comma-separated list. If empty, Pulse Desk finds *.session files automatically.
# Do not reuse the same *.session files on two IP addresses at the same time.
# On a second IP, set a separate PULSE_SESSION_DIR and use separate session names,
# for example TELEGRAM_SESSIONS=alga_kazakhst2n_ip2,w3v8f0rm_ip2.
TELEGRAM_SESSIONS=alga_kazakhst2n,w3v8f0rm,Fjfjfjfjds,MuverGT,Timofey02513,xdfusybau,davifd23,fsdfsdfdsg34

# Usernames to track, with or without @. Account session names go in TELEGRAM_SESSIONS, not here.
USERNAMES=alga_kazakhst2n,w3v8f0rm,Fjfjfjfjds,Timofey02513,MuverGT,xdfusybau,davifd23,fsdfsdfdsg34
EXTRA_USERNAMES=

# Optional Telegram bot notifications.
TELEGRAM_BOT_TOKEN=
ADMIN_ID=
# Extra owner chat ids with full bot control (comma-separated). ADMIN_ID is always an owner.
# Other people get read-only access via access keys (/newkey in the bot or the web panel).
BOT_ADMIN_CHATS=

# Access tokens.
# ADMIN_TOKEN can manage accounts, settings, scans, logs and exports.
# VIEWER_TOKEN can only view dashboard, pings, market and analytics.
# WEB_AUTH_TOKEN is kept for old installs and acts like ADMIN_TOKEN if ADMIN_TOKEN is empty.
# Use long different random values. Send only VIEWER_TOKEN to friends.
ADMIN_TOKEN=change-this-owner-token
VIEWER_TOKEN=change-this-friend-token
WEB_AUTH_TOKEN=
PUBLIC_SHARE_MODE=true
ALLOW_QUERY_TOKEN=false

# Keep local app bound to localhost. Share it through Cloudflare Quick Tunnel/ngrok.
HOST=127.0.0.1
PORT=8000

# Safety defaults.
AUTO_JOIN_GIVEAWAYS=false
DRY_RUN_GIVEAWAYS=true
GIVEAWAY_ACTION_ACCOUNT=alga_kazakhst2n
GIVEAWAY_REVIEW_MODE=manual
GIVEAWAY_ANALYZE_RECENT_MESSAGES=50
GIVEAWAY_INACTIVE_CHANNEL_DAYS=14
GIVEAWAY_MIN_ACTION_DELAY_SECONDS=45

# Background jobs.
SCAN_INTERVAL_SECONDS=900
SCAN_ACCOUNT_CONCURRENCY=3
# 0 means no per-username history cap.
SCAN_HISTORY_LIMIT=0
# Recent channel posts checked again on every background scan to catch edited winner posts.
# 0 disables the edited-post safety sweep.
EDIT_SCAN_RECENT_MESSAGES=20
STARTUP_SCAN_DELAY_SECONDS=8
STARTUP_SCAN_WAIT_SECONDS=30
TELEGRAM_CONNECT_TIMEOUT_SECONDS=30
TELEGRAM_RETRY_DELAY_SECONDS=8
TELEGRAM_RECONNECT_BASE_SECONDS=20
TELEGRAM_RECONNECT_MAX_SECONDS=300
TELEGRAM_RECONNECT_JITTER_SECONDS=15
MARKET_POLL_SECONDS=300
MARKET_ALERT_CHANGE_PCT=5.0
MARKET_RETENTION_DAYS=7
BACKUP_RETENTION=10
PENDING_AUTH_TTL_SECONDS=600

# Logging.
LOG_LEVEL=INFO
TELETHON_LOG_LEVEL=WARNING

# Keyword lists may contain Russian, Ukrainian and English words.
WIN_KEYWORDS=победитель,выиграл,выиграла,вы выиграли,поздравляем,забрать приз,winner,win,congratulations,переможець,виграв
GIVEAWAY_KEYWORDS=фаст,конкурс,розыгрыш,условия,условие,итоги
JOIN_BUTTON_KEYWORDS=участвовать,participate,join,вступить,зарегистрироваться,register

# Optional custom database location.
PULSE_DB_PATH=

# Optional runtime directories. By default Pulse Desk uses ./data, ./sessions and ./logs.
# Use a unique directory per IP/machine if you run the same Telegram accounts elsewhere.
PULSE_SESSION_DIR=
PULSE_LOG_DIR=
